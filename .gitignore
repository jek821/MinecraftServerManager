# World data (large binary files)
worldFiles/

# Legacy root paintings folder (images now live inside worldFiles/<world>/paintings/)
paintings/

# Server jars
jars/

# Runtime config (contains local IP)
config.json

# Auto-generated TLS certs for optional HTTPS resource packs
.certs/

# Flask secret key (generated at runtime)
.secret_key
webapp/.secret_key

# Minecraft server unpacked files
webapp/libraries/
webapp/versions/
libraries/
versions/

# Logs
webapp/logs/
logs/

# Python
**/__pycache__/
*.pyc
*.pyo
